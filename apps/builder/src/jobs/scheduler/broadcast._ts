import { JOB_NAMES } from "@/scheduler/types"
import { flowQueue } from "@/workers/flow.worker"
import { BroadcastStatus, prisma } from "@aha.chat/database"

export default async (datetime: Date = new Date()) => {
  const broadcasts = await prisma.broadcast.findMany({
    where: {
      status: BroadcastStatus.scheduled,
      schedulesAt: {
        lte: datetime,
      },
    },
    include: {
      contacts: true,
    },
  })

  for (const broadcast of broadcasts) {
    for (const contact of broadcast.contacts) {
      flowQueue.add(JOB_NAMES.StartFlow, {
        flowId: broadcast.flowId,
        contactId: contact.contactId,
      })
    }
  }
}
