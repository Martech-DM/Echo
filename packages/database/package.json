{
  "name": "@aha.chat/database",
  "version": "0.1.0",
  "type": "module",
  "dependencies": {
    "@aha.chat/logger": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/adapter-pg": "6.17.0",
    "@prisma/client": "6.17.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@t3-oss/env-nextjs": "^0.13.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@aha.chat/typescript-config": "workspace:*",
    "@faker-js/faker": "^10.0.0",
    "@types/node": "^24.7.0",
    "dotenv-cli": "^10.0.0",
    "prisma": "6.17.0",
    "ts-node": "^10.9.2"
  },
  "scripts": {
    "make:migration": "dotenv -e ../../.env -- ./scripts/make-migration.sh",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx src/seeders/index.ts",
    "db:client": "dotenv -e ../../.env -- prisma generate",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:setup": "pnpm migrate && pnpm db:client && pnpm db:seed",
    "db:rollback": "dotenv -e ../../.env -- ./scripts/db-rollback.sh",
    "migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:squash": "dotenv -e ../../.env -- ./scripts/squash-migrations.sh",
    "migrate:status": "dotenv -e ../../.env -- prisma migrate status"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./keys": "./src/keys.ts"
  }
}
